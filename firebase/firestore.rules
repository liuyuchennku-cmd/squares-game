rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isPlayer(roomId) {
      return signedIn()
        && exists(/databases/$(database)/documents/rooms/$(roomId)/players/$(request.auth.uid));
    }

    function isHost(roomId) {
      return signedIn()
        && get(/databases/$(database)/documents/rooms/$(roomId)).data.hostUid == request.auth.uid;
    }

    function validSkin(skinId) {
      return skinId is string
        && skinId in [
          'base', 'classic', 'ocean', 'forest', 'ember', 'neon', 'glowing_mycelium',
          'rope_knots', 'star_constellation', 'thunder_pulse', 'vine_path', 'carved_wood'
        ];
    }

    match /rooms/{roomId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.hostUid == request.auth.uid;
      allow update: if isHost(roomId)
        || (
          isPlayer(roomId)
          && request.resource.data.mode == resource.data.mode
          && request.resource.data.boardSize == resource.data.boardSize
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'snapshot',
            'status',
            'lastActionType',
            'lastActionBy',
            'updatedAt'
          ])
        );

      match /players/{playerId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.auth.uid == playerId
          && request.resource.data.uid == playerId
          && request.resource.data.name is string
          && request.resource.data.name.size() <= 16
          && validSkin(request.resource.data.skinId)
          && request.resource.data.keys().hasOnly([
            'uid',
            'name',
            'color',
            'skinId',
            'host',
            'connected',
            'joinedAt',
            'lastSeen'
          ]);
        allow update: if signedIn()
          && request.auth.uid == playerId
          && request.resource.data.uid == resource.data.uid
          && validSkin(request.resource.data.skinId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'name',
            'skinId',
            'connected',
            'lastSeen'
          ]);
      }

      match /colorSeats/{color} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      }

      match /results/{resultId} {
        allow read: if signedIn();
        allow create: if isPlayer(roomId);
      }
    }

    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == userId
        && validSkin(request.resource.data.skinId)
        && request.resource.data.keys().hasOnly([
          'uid',
          'skinId',
          'createdAt',
          'updatedAt'
        ]);
      allow update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == resource.data.uid
        && validSkin(request.resource.data.skinId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'skinId',
          'updatedAt'
        ]);
    }

    match /rankings/{userId} {
      allow read: if true;
      allow create, update: if signedIn();
    }
  }
}
